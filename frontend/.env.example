# Gateway origin — every API call goes here (never a service port directly).
NEXT_PUBLIC_API_BASE=http://localhost:8080

# 1 = in-browser mock API (full seed data, works with zero backend).
# 0 = real gateway. Endpoints the backend hasn't shipped yet will surface
#     their errors as directional messages; flip back to 1 to keep demoing.
NEXT_PUBLIC_USE_MOCKS=0
